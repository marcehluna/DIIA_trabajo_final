# LLM vía API HTTP compatible (Ollama local, etc.). El valor `openai` sigue aceptado como alias de `http`.
# REGATAS_LLM_BACKEND=http
# REGATAS_LLM_BASE_URL=http://127.0.0.1:11434/v1
# REGATAS_LLM_API_KEY=ollama
# REGATAS_LLM_MODEL=llama3

# RAG: lexical | http | local  (openai = alias legacy de http)
# REGATAS_EMBEDDING_BACKEND=lexical
# REGATAS_EMBEDDING_MODEL=text-embedding-3-small

# System prompt del IU: es | en (el informe sigue en español)
# REGATAS_SYSTEM_PROMPT_LANG=es

# Plantilla de system prompt: cot (Chain-of-Thought explícito) | few_shot_cot (Few-Shot CoT; ranura de ejemplos en prompts.py)
# REGATAS_PROMPT_STRATEGY=cot

# Alternativas si no usás las REGATAS_LLM_* de arriba (nombres de entorno heredados del ecosistema):
# OPENAI_BASE_URL=...
# OPENAI_API_KEY=...
# OPENAI_LLM_MODEL=...
