# Copiar a .env y ajustar. Sin .env: REGATAS_PROFILE=production (retrieval E11, prompt v3 / E13).

# --- Perfil RAG ---
# production (defecto): JSONL processed + cupos 2+3+2+1
# baseline: solo PDF Call+Case (E0 histórico)
# legacy: full JSONL+PDF sin cupos
# REGATAS_PROFILE=production

# --- LLM ---
REGATAS_LLM_BACKEND=http
REGATAS_LLM_BASE_URL=http://127.0.0.1:11434/v1
REGATAS_LLM_API_KEY=ollama
REGATAS_LLM_MODEL=qwen2.5:14b-instruct
REGATAS_SYSTEM_PROMPT_LANG=es
# Idioma del informe: es (defecto, E13) | en (experimento E14, alineado al corpus)
# REGATAS_RESPONSE_LANG=es
REGATAS_PROMPT_STRATEGY=cot
REGATAS_LLM_TIMEOUT=600

# --- Corpus (production: processed; override solo si hace falta) ---
# REGATAS_CORPUS_SOURCES=processed
# REGATAS_CORPUS_FILES=
# REGATAS_LOAD_PROCESSED=1

# --- Retrieval cupos E11 (production ya los aplica; descomentar para forzar) ---
# REGATAS_RETRIEVAL_QUOTAS=1
# REGATAS_RETRIEVAL_QUOTA_BY_DOCTYPE=1
# REGATAS_RETRIEVAL_QUOTA_RRS=2
# REGATAS_RETRIEVAL_QUOTA_CALL=3
# REGATAS_RETRIEVAL_QUOTA_CASE=2
# REGATAS_RETRIEVAL_QUOTA_DEFINITION=1

# --- Embeddings: lexical (E11) | http | local | hybrid ---
REGATAS_EMBEDDING_BACKEND=lexical
# Híbrido léxico + semántica (RRF); compatible con cupos por doc_type
# REGATAS_EMBEDDING_BACKEND=hybrid
# REGATAS_HYBRID_SEMANTIC_BACKEND=local
# REGATAS_HYBRID_RRF_K=60

# REGATAS_EMBEDDING_BACKEND=http
# REGATAS_EMBEDDING_MODEL=text-embedding-3-small

# --- App ---
REGATAS_ACTIVITY_CONSOLE=0
REGATAS_PRELOAD_PIPELINE=1

# Baseline E0 (solo PDF, sin JSONL ni cupos):
# REGATAS_PROFILE=baseline
# REGATAS_LOAD_PROCESSED=0
