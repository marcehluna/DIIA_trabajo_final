                    <mxGeometry x="1760" y="338" width="280" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="met8" value="&lt;div style=&quot;text-align:center&quot;&gt;&lt;b&gt;Métricas&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align:left;font-size:9px&quot;&gt;R@k reglas: &lt;b&gt;0.20&lt;/b&gt;&lt;br&gt;R@k CALL: &lt;b&gt;0.13&lt;/b&gt;&lt;br&gt;F1 RRS: 0.14 · F1 CALL: 0.13&lt;br&gt;Jaccard ref: 0.12&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="2060" y="338" width="280" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="met9" value="&lt;div style=&quot;text-align:center&quot;&gt;&lt;b&gt;Métricas&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align:left;font-size:9px&quot;&gt;R@k reglas: &lt;b&gt;0.20&lt;/b&gt;&lt;br&gt;R@k CALL: &lt;b&gt;0.13&lt;/b&gt;&lt;br&gt;F1 RRS: 0.16 · F1 CALL: 0.13&lt;br&gt;Jaccard ref: 0.12&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="2360" y="338" width="280" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="met10" value="&lt;div style=&quot;text-align:center&quot;&gt;&lt;b&gt;Métricas&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align:left;font-size:9px&quot;&gt;R@k reglas: &lt;b&gt;0.69&lt;/b&gt;&lt;br&gt;R@k CALL: &lt;b&gt;0.07&lt;/b&gt;&lt;br&gt;F1 RRS: 0.09 · F1 CALL: 0.07&lt;br&gt;Jaccard ref: 0.13&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="2650" y="338" width="300" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="met11" value="&lt;div style=&quot;text-align:center&quot;&gt;&lt;b&gt;Métricas&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align:left;font-size:9px&quot;&gt;R@k reglas: &lt;b&gt;0.76&lt;/b&gt;&lt;br&gt;R@k CALL: &lt;b&gt;0.20&lt;/b&gt;&lt;br&gt;F1 RRS: 0.25 · F1 CALL: 0.07&lt;br&gt;Jaccard ref: 0.12 · Dictamen: 0%&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="2960" y="338" width="300" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="met12" value="&lt;div style=&quot;text-align:center&quot;&gt;&lt;b&gt;Métricas&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align:left;font-size:9px&quot;&gt;R@k reglas: &lt;b&gt;0.76&lt;/b&gt;&lt;br&gt;R@k CALL: &lt;b&gt;0.20&lt;/b&gt;&lt;br&gt;F1 RRS: 0.20 · F1 CALL: 0.13&lt;br&gt;Jaccard ref: 0.13 · Dictamen: 60%&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="3270" y="338" width="300" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="met13" value="&lt;div style=&quot;text-align:center&quot;&gt;&lt;b&gt;Métricas&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align:left;font-size:9px&quot;&gt;R@k reglas: &lt;b&gt;0.76&lt;/b&gt;&lt;br&gt;R@k CALL: &lt;b&gt;0.20&lt;/b&gt;&lt;br&gt;F1 RRS: 0.22 · F1 CALL: 0.07&lt;br&gt;Jaccard ref: 0.16 · Dictamen: 60%&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="3600" y="343" width="300" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="d12" value="03-jun" style="text;html=1;align=center;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="3310" y="210" width="60" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="d13" value="04-jun" style="text;html=1;align=center;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="3640" y="210" width="60" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="metricasDoc" value="&lt;b&gt;Guía de métricas (eval RAG — asistente de protestas)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Golden set: 15 casos con reglas RRS, CALL y decisión esperada. Promedios sobre casos donde aplica cada métrica. Retrieval con top_k=8 (léxico).&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;&lt;font style=&quot;font-size:10px&quot;&gt;R@k reglas · R@k CALL&lt;/font&gt;&lt;/b&gt; &lt;font style=&quot;font-size:9px&quot;&gt;(Recall@k — &lt;b&gt;recuperación&lt;/b&gt;)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Qué mide:&lt;/b&gt; De las referencias esperadas en el golden set, ¿cuántas aparecen en al menos un fragmento del top_k recuperado? (matcher por código: p. ej. Regla 16.1 / Rule 16.1, CALL A3).&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Por qué importa:&lt;/b&gt; Si el contexto no trae la norma correcta, el LLM no puede fundamentar bien el dictamen. Permite comparar índices (PDF vs JSONL), cupos y dilución del corpus sin depender del texto generado.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;&lt;font style=&quot;font-size:10px&quot;&gt;F1 RRS · F1 CALL&lt;/font&gt;&lt;/b&gt; &lt;font style=&quot;font-size:9px&quot;&gt;(citas en la respuesta vs golden)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Qué mide:&lt;/b&gt; F1 entre referencias &lt;b&gt;esperadas&lt;/b&gt; y las &lt;b&gt;citadas en la respuesta&lt;/b&gt; (extracción por regex). Combina precisión (citas correctas / citas dichas) y recall (esperadas citadas / esperadas).&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Por qué importa:&lt;/b&gt; Un buen R@k con F1 bajo indica que recuperamos bien pero el modelo no cita o alucina códigos. Clave para protestas náuticas donde la trazabilidad normativa (RRS + Call Book) es obligatoria.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;i&gt;E12–E13:&lt;/i&gt; F1 con parser ampliado (`**Regla …**`, viñetas). E12 mostró F1=0 en corrida por formato, no por ausencia de citas.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Jaccard ref&lt;/font&gt;&lt;/b&gt; &lt;font style=&quot;font-size:9px&quot;&gt;(solapamiento léxico respuesta ↔ output ideal)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Qué mide:&lt;/b&gt; Similitud de tokens (≥3 letras) entre la respuesta generada y la respuesta de referencia del Excel.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Por qué importa:&lt;/b&gt; Señal barata de cercanía al criterio humano del curso. &lt;i&gt;Limitación:&lt;/i&gt; corpus en inglés y respuestas en español → valores bajos aunque el contenido sea equivalente; no sustituye faithfulness ni revisión manual.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Lectura conjunta:&lt;/b&gt; R@k alto + F1 bajo → mejorar prompting/citas; R@k bajo → índice, chunking o cupos; E1/E2 solo muestran R@k (sin LLM). Detalle por caso: &lt;code&gt;report.json&lt;/code&gt;, &lt;code&gt;metrics_long.csv&lt;/code&gt;.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fc;strokeColor=#6c8ebf;align=left;spacingLeft=12;spacingRight=12;verticalAlign=top;spacingTop=8;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="30" y="510" width="1040" height="320" as="geometry"/>
                </mxCell>
                <mxCell id="d0" value="25-may" style="text;html=1;align=center;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="60" y="210" width="60" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="d10" value="26-may" style="text;html=1;align=center;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="2690" y="210" width="60" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="d11" value="26-may" style="text;html=1;align=center;fontSize=9;" parent="1" vertex="1">
                    <mxGeometry x="3000" y="210" width="60" height="20" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>